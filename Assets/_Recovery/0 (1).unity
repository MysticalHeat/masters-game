  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0e02bd8255a9d31889cb5be0c2443443, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MastersGame.Gameplay.NpcChatTarget
  npcName: Archivist
  persona: "\u041D\u0435\u0441\u043F\u0435\u0448\u043D\u044B\u0439 \u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435\u043B\u044C
    \u0442\u0435\u0441\u0442\u043E\u0432\u043E\u0439 \u043B\u043E\u043A\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442
    \u043A\u043E\u0440\u043E\u0442\u043A\u043E, \u043F\u043E\u043D\u044F\u0442\u043D\u043E
    \u0438 \u043F\u043E \u0434\u0435\u043B\u0443."
  greeting: "\u042F \u0441\u043B\u0435\u0436\u0443 \u0437\u0430 \u044D\u0442\u043E\u0439
    \u0442\u0435\u0441\u0442\u043E\u0432\u043E\u0439 \u043F\u043B\u043E\u0449\u0430\u0434\u043A\u043E\u0439.
    \u0421\u043F\u0440\u043E\u0441\u0438 \u043C\u0435\u043D\u044F \u043E \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u0435,
    \u043C\u043E\u0434\u0435\u043B\u0438 \u0438\u043B\u0438 \u0441\u0430\u043C\u043E\u0439
    \u0441\u0446\u0435\u043D\u0435."
  interactionHint: Press E / Interact to talk
